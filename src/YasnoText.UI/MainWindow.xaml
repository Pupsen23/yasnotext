<Window x:Class="YasnoText.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ЯсноТекст"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="{DynamicResource UIFontFamily}">

    <Window.Resources>
        <!-- Стиль для кнопок панели инструментов -->
        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontFamily="{TemplateBinding FontFamily}"
                                              TextElement.FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WindowBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для пунктов меню верхнего уровня -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        </Style>

        <!-- Стиль для самого Menu -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть..." InputGestureText="Ctrl+O" />
                <MenuItem Header="Сохранить" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="Выход" />
            </MenuItem>
            <MenuItem Header="Профиль">
                <MenuItem Header="Стандартный" InputGestureText="Ctrl+1" />
                <MenuItem Header="Слабовидение" InputGestureText="Ctrl+2" />
                <MenuItem Header="Дислексия" InputGestureText="Ctrl+3" />
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Увеличить шрифт" InputGestureText="Ctrl++" />
                <MenuItem Header="Уменьшить шрифт" InputGestureText="Ctrl+-" />
            </MenuItem>
            <MenuItem Header="Озвучка">
                <MenuItem Header="Прочитать вслух" />
                <MenuItem Header="Остановить" />
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" />
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource WindowBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button Content="📂 Открыть" Style="{StaticResource ToolbarButton}" />
                <Button Content="💾 Сохранить" Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="🔍 Распознать (OCR)" Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="A−" Style="{StaticResource ToolbarButton}" />
                <TextBlock Text="14pt"
                           VerticalAlignment="Center"
                           Margin="8,0"
                           MinWidth="40"
                           TextAlignment="Center"
                           Foreground="{DynamicResource TextBrush}" />
                <Button Content="A+" Style="{StaticResource ToolbarButton}" />
                <Rectangle Width="1" Margin="6,2"
                           Fill="{DynamicResource BorderBrush}" />
                <Button Content="▶ Озвучить" Style="{StaticResource ToolbarButton}" />
            </StackPanel>
        </Border>

        <!-- Строка состояния -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Готов к работе"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
                <TextBlock Grid.Column="1"
                           Text="Профиль: Стандартный · 14pt"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </Grid>
        </Border>

        <!-- Главная область: боковая панель + область чтения -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Боковая панель: профили и настройки -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="ПРОФИЛИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,0,0,8" />

                    <!-- Карточка: Стандартный (активный, выделен фоном AccentBrush) -->
                    <Border Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="2"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Стандартный"
                                       FontWeight="Bold"
                                       FontSize="13"
                                       Foreground="{DynamicResource WindowBackgroundBrush}" />
                            <TextBlock Text="Активен · Ctrl+1"
                                       FontSize="11"
                                       Foreground="{DynamicResource WindowBackgroundBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Слабовидение -->
                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6"
                            Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="Слабовидение"
                                       FontWeight="Medium"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="Ctrl+2"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Дислексия -->
                    <Border Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6"
                            Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="Дислексия"
                                       FontWeight="Medium"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextBrush}" />
                            <TextBlock Text="Ctrl+3"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="НАСТРОЙКИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,16,0,8" />

                    <TextBlock Text="Шрифт"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <ComboBox SelectedIndex="0"
                              Margin="0,0,0,10"
                              Foreground="Black">
                        <ComboBoxItem Content="Segoe UI" />
                        <ComboBoxItem Content="Arial" />
                        <ComboBoxItem Content="OpenDyslexic" />
                    </ComboBox>

                    <TextBlock Text="Межбуквенный интервал"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <Slider Minimum="0" Maximum="10" Value="0" Margin="0,0,0,10" />

                    <TextBlock Text="Высота строки"
                               FontSize="12"
                               Margin="0,0,0,4"
                               Foreground="{DynamicResource TextBrush}" />
                    <Slider Minimum="1" Maximum="3" Value="1.5" TickFrequency="0.5" />
                </StackPanel>
            </Border>

            <!-- Область чтения -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource ReadingBackgroundBrush}">
                <FlowDocumentScrollViewer x:Name="ReaderViewer"
                                          Padding="32,24"
                                          Background="{DynamicResource ReadingBackgroundBrush}"
                                          Foreground="{DynamicResource TextBrush}"
                                          VerticalScrollBarVisibility="Hidden">
                    <FlowDocument FontFamily="{DynamicResource ReadingFontFamily}"
                                  FontSize="{DynamicResource ReadingFontSize}"
                                  FontWeight="{DynamicResource ReadingFontWeight}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Background="{DynamicResource ReadingBackgroundBrush}"
                                  PagePadding="0">
                        <Paragraph FontSize="20" FontWeight="Medium">
                            Добро пожаловать в ЯсноТекст
                        </Paragraph>
                        <Paragraph>
                            Это приложение помогает превратить «недоступные» цифровые документы
                            в удобную среду для людей с нарушениями зрения и дислексией.
                        </Paragraph>
                        <Paragraph>
                            Чтобы начать, нажмите кнопку «Открыть» на панели инструментов
                            или перетащите PDF/DOCX-файл в эту область.
                        </Paragraph>
                        <Paragraph>
                            Выберите подходящий профиль слева — интерфейс автоматически
                            подстроится под ваши потребности.
                        </Paragraph>
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </ScrollViewer>
        </Grid>

    </DockPanel>
</Window>
