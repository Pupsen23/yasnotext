<Window x:Class="YasnoText.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ЯсноТекст"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

    <DockPanel>

        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Открыть..." InputGestureText="Ctrl+O" />
                <MenuItem Header="Сохранить" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="Выход" />
            </MenuItem>
            <MenuItem Header="Профиль">
                <MenuItem Header="Стандартный" InputGestureText="Ctrl+1" />
                <MenuItem Header="Слабовидение" InputGestureText="Ctrl+2" />
                <MenuItem Header="Дислексия" InputGestureText="Ctrl+3" />
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Увеличить шрифт" InputGestureText="Ctrl++" />
                <MenuItem Header="Уменьшить шрифт" InputGestureText="Ctrl+-" />
            </MenuItem>
            <MenuItem Header="Озвучка">
                <MenuItem Header="Прочитать вслух" />
                <MenuItem Header="Остановить" />
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" />
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="📂 Открыть" Padding="8,4" Margin="2" />
                <Button Content="💾 Сохранить" Padding="8,4" Margin="2" />
                <Separator />
                <Button Content="🔍 Распознать (OCR)" Padding="8,4" Margin="2" />
                <Separator />
                <Button Content="A−" Padding="8,4" Margin="2" />
                <TextBlock Text="14pt" VerticalAlignment="Center" Margin="6,0" MinWidth="36" TextAlignment="Center" />
                <Button Content="A+" Padding="8,4" Margin="2" />
                <Separator />
                <Button Content="▶ Озвучить" Padding="8,4" Margin="2" />
            </ToolBar>
        </ToolBarTray>

        <!-- Строка состояния -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="Готов к работе" />
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Профиль: Стандартный · 14pt" />
            </StatusBarItem>
        </StatusBar>

        <!-- Главная область: боковая панель + область чтения -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Боковая панель: профили и настройки -->
            <Border Grid.Column="0"
                    Background="#F5F5F0"
                    BorderBrush="#D0D0C8"
                    BorderThickness="0,0,1,0"
                    Padding="12">
                <StackPanel>
                    <TextBlock Text="ПРОФИЛИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="#666"
                               Margin="0,0,0,8" />

                    <!-- Карточка: Стандартный -->
                    <Border Background="White"
                            BorderBrush="#1E88E5"
                            BorderThickness="2"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Стандартный" FontWeight="Medium" FontSize="13" />
                            <TextBlock Text="Активен · Ctrl+1" FontSize="11" Foreground="#1E88E5" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Слабовидение -->
                    <Border Background="White"
                            BorderBrush="#D0D0C8"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6"
                            Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="Слабовидение" FontWeight="Medium" FontSize="13" />
                            <TextBlock Text="Ctrl+2" FontSize="11" Foreground="#888" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Карточка: Дислексия -->
                    <Border Background="White"
                            BorderBrush="#D0D0C8"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,8"
                            Margin="0,0,0,6"
                            Cursor="Hand">
                        <StackPanel>
                            <TextBlock Text="Дислексия" FontWeight="Medium" FontSize="13" />
                            <TextBlock Text="Ctrl+3" FontSize="11" Foreground="#888" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="НАСТРОЙКИ"
                               FontSize="11"
                               FontWeight="Medium"
                               Foreground="#666"
                               Margin="0,16,0,8" />

                    <TextBlock Text="Шрифт" FontSize="12" Margin="0,0,0,4" />
                    <ComboBox SelectedIndex="0" Margin="0,0,0,10">
                        <ComboBoxItem Content="Segoe UI" />
                        <ComboBoxItem Content="Arial" />
                        <ComboBoxItem Content="OpenDyslexic" />
                    </ComboBox>

                    <TextBlock Text="Межбуквенный интервал" FontSize="12" Margin="0,0,0,4" />
                    <Slider Minimum="0" Maximum="10" Value="0" Margin="0,0,0,10" />

                    <TextBlock Text="Высота строки" FontSize="12" Margin="0,0,0,4" />
                    <Slider Minimum="1" Maximum="3" Value="1.5" TickFrequency="0.5" />
                </StackPanel>
            </Border>

            <!-- Область чтения -->
            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          Background="White">
                <FlowDocumentScrollViewer x:Name="ReaderViewer"
                                          Padding="32,24"
                                          VerticalScrollBarVisibility="Hidden">
                    <FlowDocument FontFamily="Segoe UI" FontSize="14" PagePadding="0">
                        <Paragraph FontSize="20" FontWeight="Medium">
                            Добро пожаловать в ЯсноТекст
                        </Paragraph>
                        <Paragraph>
                            Это приложение помогает превратить «недоступные» цифровые документы
                            в удобную среду для людей с нарушениями зрения и дислексией.
                        </Paragraph>
                        <Paragraph>
                            Чтобы начать, нажмите кнопку «Открыть» на панели инструментов
                            или перетащите PDF/DOCX-файл в эту область.
                        </Paragraph>
                        <Paragraph>
                            Выберите подходящий профиль слева — интерфейс автоматически
                            подстроится под ваши потребности.
                        </Paragraph>
                    </FlowDocument>
                </FlowDocumentScrollViewer>
            </ScrollViewer>
        </Grid>

    </DockPanel>
</Window>
